<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>VTWorld — Hồ Sơ</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="style.css"/>
  <link rel="stylesheet" href="profile.css"/>
  <link rel="stylesheet" href="pet.css"/>
  <link rel="stylesheet" href="shop-bag.css"/>
  <link rel="stylesheet" href="character.css"/>
</head>
<body>
  <canvas id="bg-canvas"></canvas>
  <div class="orb orb1"></div>
  <div class="orb orb2"></div>

  <nav>
    <div class="logo" onclick="location.href='index.html'" style="cursor:pointer">
      <span class="logo-vt">VT</span><span class="logo-world">World</span>
    </div>
    
    <!-- Nút 3 gạch với Bag + Quay lại -->
    <div class="nav-right-menu">
      <button class="nav-hamburger" onclick="toggleNavMenu()">☰</button>
      <div class="nav-dropdown" id="navDropdown">
        <a class="nav-dropdown-item" href="bag.html">
          <span class="dd-icon">🎒</span> Bag
        </a>
        <a class="nav-dropdown-item" href="#" onclick="history.back();return false;">
          <span class="dd-icon">←</span> Quay lại
        </a>
      </div>
    </div>
  </nav>

  <div class="pro-wrap">
    <!-- BANNER -->
    <div class="pro-banner">
      <div class="pro-banner-bg"></div>
    </div>

    <!-- AVATAR -->
    <div style="display:flex;justify-content:center;margin-top:-46px;margin-bottom:12px;position:relative;z-index:10">
      <div style="position:relative;width:92px;height:92px;">
        <div class="pro-avatar-ring">
          <div class="pro-avatar" id="pro-avatar">?</div>
        </div>
        <label class="pro-avatar-upload" id="pro-avatar-upload-btn" title="Đổi ảnh">
          📷
          <input type="file" id="pro-avatar-input" accept="image/*" style="display:none"/>
        </label>
      </div>
    </div>

    <!-- TÊN + ĐIỂM -->
    <div class="pro-identity">
      <h1 class="pro-name" id="pro-name">Đang tải...</h1>
      <div class="pro-points-row">
        <span class="pro-points-icon">⭐</span>
        <span class="pro-points-val" id="pro-points">0</span>
        <span class="pro-points-label">điểm</span>
      </div>
    </div>

    <!-- GRID MỚI: Nhân vật (trái, to) | Pet (phải trên) + Danh hiệu (phải dưới) -->
    <div class="pro-grid">
      <!-- Ô NHÂN VẬT (to, trái) -->
      <div class="pro-card pro-card-character" onclick="location.href='character.html'" style="cursor:pointer">
        <div class="pro-character-frame" id="pro-character-frame"></div>
        <div class="pro-card-sub" id="pro-char-name">Nhấn để tùy chỉnh →</div>
      </div>

      <!-- Ô THÚ CƯNG (phải trên) -->
      <div class="pro-card pro-card-pet" onclick="window.openPetModal?.()">
        <div class="pro-pet-frame" id="pro-pet-frame">
          <div class="pro-pet-placeholder">
            <span class="pro-pet-emoji">🥚</span>
            <span class="pro-coming-soon">Bấm để gacha</span>
          </div>
        </div>
        <div class="pro-card-sub" id="pro-card-pet-sub">Chưa có thú cưng</div>
      </div>

      <!-- Ô DANH HIỆU (phải dưới) -->
      <div class="pro-card pro-card-title">
        <div class="pro-card-label">🏅 Danh hiệu</div>
        <div class="pro-titles-list" id="pro-titles-list"></div>
      </div>
    </div>

    <!-- STATS ROW -->
    <div class="pro-stats-row">
      <div class="pro-stat">
        <span class="pro-stat-val" id="pro-stat-friends">—</span>
        <span class="pro-stat-label">Bạn bè</span>
      </div>
      <div class="pro-stat">
        <span class="pro-stat-val" id="pro-stat-rank">—</span>
        <span class="pro-stat-label">Xếp hạng</span>
      </div>
      <div class="pro-stat">
        <span class="pro-stat-val" id="pro-stat-joined">—</span>
        <span class="pro-stat-label">Tham gia</span>
      </div>
    </div>
  </div>

  <script>
    function toggleNavMenu() {
      document.getElementById('navDropdown').classList.toggle('open');
    }
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.nav-right-menu')) {
        document.getElementById('navDropdown').classList.remove('open');
      }
    });
  </script>

  <script type="module" src="character.js"></script>
  <script type="module" src="profile.js"></script>
  <script type="module">
    window.openBagModal = () => { location.href = 'bag.html'; };
  </script>
</body>
</html>